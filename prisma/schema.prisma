generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

/**
 * ===================== ENUMS =====================
 */

enum UserRole {
  user
  schoolAdmin
  teacher
  student
  superAdmin
}

enum Medium {
  English
  Malayalam
  Tamil
  Hindi
  Urdu
  Arabic
  Other
}

enum OnboardingStatus {
  PENDING
  COMPLETED
}

enum GradingSystem {
  GPA
  PERCENTAGE
  LETTER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

/**
 * ===================== SCHOOL =====================
 */

model School {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  logo             String?
  address          String?
  website          String?
  onboardingStatus OnboardingStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  classes       Class[]
  academicYears AcademicYear[]
  teachers      Teacher[]
  exams         Exam[]
  feeCategories FeeCategory[]
  invoices      Invoice[]
  subjects      Subject[]
}

/**
 * ===================== USER =====================
 */

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean?
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  role          UserRole

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  studentProfile StudentProfile?
  teacherProfile Teacher?
  invitations    Invitation[]

  @@index([schoolId])
  @@map("user")
}

/**
 * ===================== AUTH =====================
 */

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime
  updatedAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  activeOrganizationId String?

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Invitation {
  id             String   @id
  organizationId String
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User     @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model AcademicYear {
  id            String        @id @default(cuid())
  name          String
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean       @default(false)
  gradingSystem GradingSystem @default(GPA)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  terms    Term[]
  exams    Exam[]
  invoices Invoice[]

  @@index([schoolId])
}

model Term {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams          Exam[]

  @@index([academicYearId])
}

/**
 * ===================== SUBJECT =====================
 */

model Subject {
  id       String @id @default(cuid())
  name     String
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classSubjects ClassSubject[]
  examSubjects  ExamSubject[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

/**
 * ===================== TEACHER =====================
 */

model Teacher {
  id       String @id @default(cuid())
  userId   String @unique
  schoolId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id])

  isActive Boolean @default(true)

  // one class → one class teacher
  classTeacherOf Class?

  // many subject assignments
  classSubjects ClassSubject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

/**
 * ===================== CLASS =====================
 */

model Class {
  id       String @id @default(cuid())
  name     String
  grade    String
  section  String
  medium   Medium
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // 🔒 ONE CLASS → ONE CLASS TEACHER
  classTeacherId String?  @unique
  classTeacher   Teacher? @relation(fields: [classTeacherId], references: [id])

  students      StudentProfile[]
  classSubjects ClassSubject[]
  attendances   Attendance[]
  examSubjects  ExamSubject[]

  isActive Boolean?
  capacity Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

/**
 * ===================== CLASS–SUBJECT–TEACHER =====================
 */

model ClassSubject {
  id        String @id @default(cuid())
  classId   String
  teacherId String
  subjectId String

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, teacherId, subjectId])
  @@index([classId])
  @@index([teacherId])
  @@index([subjectId])
}

/**
 * ===================== STUDENT =====================
 */

model StudentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // personal
  dob        DateTime?
  gender     Gender?
  phone      String?
  address    String?
  fatherName String?
  motherName String?
  isActive   Boolean   @default(true)
  bloodGroup String?

  // guardian
  guardianName     String?
  guardianPhone    String?
  guardianEmail    String?
  guardianRelation String?

  // academic
  admissionNumber String?
  rollNumber      String?
  joiningDate     DateTime?
  imageKey        String? // R2 key only

  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  attendances Attendance[]
  examScores  ExamScore[]
  invoices    Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId])
  @@index([admissionNumber])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  status    AttendanceStatus
  remarks   String?

  studentId String
  student   StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  classId   String
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([classId])
  @@index([date])
}

model Exam {
  id             String        @id @default(cuid())
  name           String
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  termId         String?
  term           Term?         @relation(fields: [termId], references: [id], onDelete: Cascade)
  examSubjects   ExamSubject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([academicYearId])
}

model ExamSubject {
  id           String      @id @default(cuid())
  examId       String
  exam         Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  classId      String
  class        Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId    String
  subject      Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  maxMarks     Float       @default(100)
  passingMarks Float       @default(35)
  examDate     DateTime?
  scores       ExamScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, classId, subjectId])
  @@index([examId])
  @@index([classId])
  @@index([subjectId])
}

model ExamScore {
  id            String         @id @default(cuid())
  examSubjectId String
  examSubject   ExamSubject    @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marksObtained Float
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examSubjectId, studentId])
  @@index([examSubjectId])
  @@index([studentId])
}

enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  ONLINE
}

model FeeCategory {
  id          String        @id @default(cuid())
  name        String
  description String?
  amount      Float
  schoolId    String
  school      School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  invoiceItems InvoiceItem[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([schoolId])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  dueDate        DateTime
  status         InvoiceStatus @default(UNPAID)
  
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  items          InvoiceItem[]
  payments       Payment[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([studentId])
  @@index([schoolId])
}

model InvoiceItem {
  id            String      @id @default(cuid())
  invoiceId     String
  invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  feeCategoryId String
  feeCategory   FeeCategory @relation(fields: [feeCategoryId], references: [id])
  amount        Float

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([invoiceId])
  @@index([feeCategoryId])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  paymentDate   DateTime
  paymentMethod PaymentMethod
  reference     String?
  remarks       String?
  
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([invoiceId])
}
